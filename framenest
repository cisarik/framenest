#!/usr/bin/env fish

set -g script_dir (dirname (status filename))
set -g repo_root (realpath "$script_dir")
set -g controller "$repo_root/.venv/bin/framenest-dev"
set -g ai_controller "$repo_root/.venv/bin/framenest-ai"
set -g backup_controller "$repo_root/.venv/bin/framenest-backup"
set -g library_python "$repo_root/.venv/bin/python"
set -g youtube_controller "$repo_root/.venv/bin/framenest-youtube"
set -g local_ai_env "$repo_root/.secrets/ai.env.fish"
set -gx POETRY_VIRTUALENVS_IN_PROJECT true

function _framenest_help
    echo "FrameNest local development launcher"
    echo ""
    echo "Usage:"
    echo "  ./framenest setup"
    echo "  ./framenest start [--no-open]"
    echo "  ./framenest stop"
    echo "  ./framenest restart [--no-open]"
    echo "  ./framenest status"
    echo "  ./framenest open"
    echo "  ./framenest logs [--follow]"
    echo "  ./framenest ai status"
    echo "  ./framenest ai configure"
    echo "  ./framenest ai test"
    echo "  ./framenest backup create"
    echo "  ./framenest backup verify"
    echo "  ./framenest backup restore"
    echo "  ./framenest library status"
    echo "  ./framenest library add"
    echo "  ./framenest library refresh"
    echo "  ./framenest youtube ingest URL"
    echo "  ./framenest youtube status CLAIM_ID"
    echo "  ./framenest youtube retry CLAIM_ID"
    echo "  ./framenest previews status"
    echo "  ./framenest previews generate"
    echo "  ./framenest --help"
    echo "  ./framenest <command> --help"
end

function _framenest_setup
    if not command -q uv
        echo "FrameNest setup requires uv." >&2
        return 127
    end
    if not command -q poetry
        echo "FrameNest setup requires Poetry." >&2
        return 127
    end

    set -l python_path
    set python_path (command uv python find 3.13.14 2>/dev/null)
    if test $status -ne 0
        echo "Installing CPython 3.13.14 with uv..."
        command uv python install 3.13.14
        or return $status
        set python_path (command uv python find 3.13.14)
        or return $status
    end

    cd "$repo_root"
    or return $status
    command poetry env use "$python_path"
    or return $status
    command poetry install --no-interaction
    or return $status

    if not test -x "$controller"
        echo "FrameNest setup failed: development controller is unavailable." >&2
        return 1
    end

    echo "FrameNest setup complete."
end

function _framenest_load_local_ai_env
    if not test -e "$local_ai_env"
        return 0
    end
    if test -L "$local_ai_env"
        echo "FrameNest local AI secrets file is unsafe." >&2
        return 1
    end
    if not test -f "$local_ai_env"
        echo "FrameNest local AI secrets file is unsafe." >&2
        return 1
    end

    set -l current_uid (id -u)
    set -l stat_output
    set -l stat_fields
    set stat_output (command stat -f "%u %Lp" "$local_ai_env" 2>/dev/null)
    if test $status -ne 0
        set stat_output (command stat -c "%u %a" "$local_ai_env" 2>/dev/null)
        if test $status -ne 0
            echo "FrameNest local AI secrets file metadata is unavailable." >&2
            return 1
        end
    end
    set stat_fields (string split " " -- $stat_output)
    if test (count $stat_fields) -ne 2
        echo "FrameNest local AI secrets file metadata is unavailable." >&2
        return 1
    end
    if test "$stat_fields[1]" != "$current_uid"
        echo "FrameNest local AI secrets file is unsafe." >&2
        return 1
    end
    set -l group_other_permissions (math "$stat_fields[2] % 100")
    if test "$group_other_permissions" -ne 0
        echo "FrameNest local AI secrets file is unsafe." >&2
        return 1
    end
    command fish --no-execute "$local_ai_env" >/dev/null 2>/dev/null
    if test $status -ne 0
        echo "FrameNest local AI secrets file is invalid." >&2
        return 1
    end
    source "$local_ai_env" >/dev/null 2>/dev/null
    if test $status -ne 0
        echo "FrameNest local AI secrets file could not be loaded." >&2
        return 1
    end
    return 0
end

if test (count $argv) -eq 0
    _framenest_help
    exit 0
end

switch "$argv[1]"
    case --help -h
        _framenest_help
        exit 0
    case setup
        _framenest_setup
        exit $status
    case start stop restart status open logs
        if not test -x "$controller"
            _framenest_setup
            or exit $status
        end
        if contains -- "$argv[1]" start restart
            _framenest_load_local_ai_env
            or exit $status
        end
        "$controller" $argv
        exit $status
    case ai
        if not test -x "$ai_controller"
            _framenest_setup
            or exit $status
        end
        _framenest_load_local_ai_env
        or exit $status
        "$ai_controller" $argv[2..-1]
        exit $status
    case backup
        if not test -x "$backup_controller"
            _framenest_setup
            or exit $status
        end
        "$backup_controller" $argv[2..-1]
        exit $status
    case library
        if not test -x "$library_python"
            _framenest_setup
            or exit $status
        end
        cd "$repo_root"
        or exit $status
        "$library_python" -m framenest.adapters.cli.library $argv[2..-1]
        exit $status
    case previews
        if not test -x "$library_python"
            _framenest_setup
            or exit $status
        end
        cd "$repo_root"
        or exit $status
        "$library_python" -m framenest.adapters.cli.previews $argv[2..-1]
        exit $status
    case youtube
        if not test -x "$youtube_controller"
            _framenest_setup
            or exit $status
        end
        "$youtube_controller" $argv[2..-1]
        exit $status
    case '*'
        echo "Unknown FrameNest command: $argv[1]" >&2
        _framenest_help >&2
        exit 2
end
